# --- Cloudflare DDNS UI configuration ---

# HTTP port the web UI listens on
PORT=8080

# Admin login for the web UI.
# If ADMIN_PASSWORD is left blank, a random password is generated and printed
# to the container/server log ONCE on first boot — copy it from there.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Secret used to sign session cookies (any long random string).
# If left blank, one is generated and persisted to data/.session-secret so
# existing sessions survive restarts.
SESSION_SECRET=

# Where the config.json and secrets live. Defaults to ./data (mounted volume).
DATA_DIR=./data

# Opt-in: enable the "Other DDNS" tab for non-Cloudflare providers
# (DuckDNS / FreeDNS / DynDNS2 — No-IP, Dynu, Namecheap, deSEC, …). Set true to enable.
# (ENABLE_NON_CLOUDFLARE_DDNS is still accepted as a deprecated alias.)
ENABLE_OTHER_DDNS=false

# Set true to stop the footer from checking GitHub for a newer release
# (useful for air-gapped installs). Left off, it checks at most once every 6h.
DISABLE_UPDATE_CHECK=false
